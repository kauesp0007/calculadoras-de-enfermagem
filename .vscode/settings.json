{
  "compile-hero.disable-compile-files-on-did-save-code": true,

  "runOnSave.commands": [
    {
      "match": ".*[\\\\/]img[\\\\/].*\\.(png|jpg|jpeg)$",
      "command": "node log-imagens.js"
    },
    {
      "match": ".*[\\\\/]img[\\\\/].*\\.(png|jpg|jpeg)$",
      "command": "node convert-webp.js"
    }
  ],

  "cSpell.words": [
    "usuário"
  ],

  "task.allowAutomaticTasks": "on"
}